{
  "name": "nova-backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --loader tsx src/server.ts",
    "build": "tsc && esbuild src/server.ts --platform=node --bundle --format=esm --outfile=dist/server.js --external:mysql2",
    "start": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "check": "tsc -b",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "node --loader tsx src/db/seed.ts"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@trpc/server": "^11.8.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.3",
    "jose": "6.1.3",
    "mysql2": "^3.14.1",
    "nanoid": "^5.1.6",
    "superjson": "^2.2.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsx": "^4.7.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.16",
    "drizzle-kit": "^0.31.8"
  }
}
