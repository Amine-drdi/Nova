{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "installCommand": "pnpm install --frozen-lockfile --no-frozen-lockfile"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/boot.js"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ],
  "buildCommand": "pnpm run vercel-build",
  "installCommand": "pnpm install --frozen-lockfile --no-frozen-lockfile",
  "framework": "vite",
  "outputDirectory": "dist",
  "packageManager": "pnpm@8.15.0"
}